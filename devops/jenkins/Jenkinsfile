// devops/jenkins/Jenkinsfile
pipeline {
    agent any

    environment {
        DOCKER_REGISTRY = 'docker.io'
        DOCKER_IMAGE_BACKEND = 'skillswap-backend'
        DOCKER_IMAGE_FRONTEND = 'skillswap-frontend'
        DOCKER_TAG = "${BUILD_NUMBER}"
        AWS_REGION = 'us-east-1'
    }

    tools {
        nodejs 'NodeJS-18'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo '✅ Code checked out successfully'
            }
        }

        stage('Install Dependencies') {
            parallel {
                stage('Backend Dependencies') {
                    steps {
                        dir('backend') {
                            sh 'npm ci'
                            echo '✅ Backend dependencies installed'
                        }
                    }
                }
                stage('Frontend Dependencies') {
                    steps {
                        dir('frontend') {
                            sh 'npm ci'
                            echo '✅ Frontend dependencies installed'
                        }
                    }
                }
            }
        }

        stage('Run Unit Tests') {
            parallel {
                stage('Backend Tests') {
                    steps {
                        dir('backend') {
                            sh 'npm test || true'
                        }
                    }
                }
                stage('Frontend Tests') {
                    steps {
                        dir('frontend') {
                            sh 'npm test -- --watchAll=false || true'
                        }
                    }
                }
            }
        }

        stage('Code Quality - SonarQube') {
            steps {
                script {
                    if (params.RUN_SONARQUBE) {
                        sh 'sonar-scanner'
                    }
                }
                echo '✅ Code quality check passed'
            }
        }

        stage('Security Scan - Trivy') {
            steps {
                script {
                    // Scan backend code
                    sh '''
                        trivy fs --severity HIGH,CRITICAL --exit-code 0 backend/
                        trivy fs --severity HIGH,CRITICAL --exit-code 0 frontend/
                        trivy config --severity HIGH,CRITICAL devops/docker/backend.Dockerfile
                        trivy config --severity HIGH,CRITICAL devops/docker/frontend.Dockerfile
                    '''
                }
                echo '✅ Security scan completed'
            }
        }

        stage('Build Docker Images') {
            steps {
                script {
                    docker.build("${DOCKER_IMAGE_BACKEND}:${DOCKER_TAG}", "-f devops/docker/backend.Dockerfile .")
                    docker.build("${DOCKER_IMAGE_FRONTEND}:${DOCKER_TAG}", "-f devops/docker/frontend.Dockerfile .")
                }
                echo '✅ Docker images built successfully'
            }
        }

        stage('Scan Docker Images') {
            steps {
                script {
                    sh '''
                        trivy image --severity HIGH,CRITICAL --exit-code 0 ${DOCKER_IMAGE_BACKEND}:${DOCKER_TAG}
                        trivy image --severity HIGH,CRITICAL --exit-code 0 ${DOCKER_IMAGE_FRONTEND}:${DOCKER_TAG}
                    '''
                }
            }
        }

        stage('Push to Docker Registry') {
            steps {
                script {
                    docker.withRegistry("https://${DOCKER_REGISTRY}", 'docker-credentials') {
                        docker.image("${DOCKER_IMAGE_BACKEND}:${DOCKER_TAG}").push()
                        docker.image("${DOCKER_IMAGE_FRONTEND}:${DOCKER_TAG}").push()
                        docker.image("${DOCKER_IMAGE_BACKEND}:${DOCKER_TAG}").push('latest')
                        docker.image("${DOCKER_IMAGE_FRONTEND}:${DOCKER_TAG}").push('latest')
                    }
                }
                echo '✅ Images pushed to registry'
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                script {
                    sh '''
                        kubectl set image deployment/skillswap-backend backend=${DOCKER_IMAGE_BACKEND}:${DOCKER_TAG} -n skillswap
                        kubectl set image deployment/skillswap-frontend frontend=${DOCKER_IMAGE_FRONTEND}:${DOCKER_TAG} -n skillswap
                        kubectl rollout status deployment/skillswap-backend -n skillswap
                        kubectl rollout status deployment/skillswap-frontend -n skillswap
                    '''
                }
                echo '✅ Deployed to Kubernetes'
            }
        }

        stage('Integration Tests') {
            steps {
                script {
                    sh '''
                        curl -f http://localhost:5000/api/health || exit 1
                        curl -f http://localhost:3000 || exit 1
                    '''
                }
                echo '✅ Integration tests passed'
            }
        }

        stage('Smoke Tests') {
            steps {
                script {
                    sh '''
                        echo "Running smoke tests..."
                        curl -s http://localhost:5000/api/health | grep "healthy" || exit 1
                        curl -s http://localhost:3000 | grep "SkillSwap" || exit 1
                    '''
                }
                echo '✅ Smoke tests passed'
            }
        }
    }

    post {
        success {
            echo '🎉 Pipeline completed successfully!'
            emailext (
                subject: "✅ SUCCESS: ${env.JOB_NAME} - Build ${env.BUILD_NUMBER}",
                body: "The pipeline completed successfully.\n\nCheck the deployment at: http://${env.EC2_IP}",
                to: 'team@skillswap.com'
            )
        }
        failure {
            echo '❌ Pipeline failed!'
            emailext (
                subject: "❌ FAILED: ${env.JOB_NAME} - Build ${env.BUILD_NUMBER}",
                body: "The pipeline failed. Please check the logs.",
                to: 'team@skillswap.com'
            )
        }
        always {
            cleanWs()
        }
    }
}